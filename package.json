{
  "name": "skillpin",
  "version": "0.0.2",
  "description": "Trusted dependency manager for AI agent skills",
  "keywords": [
    "agent-skills",
    "ai-agents",
    "codex",
    "cli",
    "llm",
    "skills",
    "supply-chain"
  ],
  "homepage": "https://github.com/nbsp1221/skillpin#readme",
  "bugs": {
    "url": "https://github.com/nbsp1221/skillpin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbsp1221/skillpin.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "skillpin": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "router-skill/SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "skillpin": "node dist/cli.js",
    "test": "pnpm build && vitest run",
    "test:e2e": "pnpm build && vitest run test/e2e",
    "test:integration": "vitest run test/integration",
    "test:package": "pnpm build && node scripts/check-package.mjs",
    "test:release": "pnpm typecheck && pnpm test && pnpm test:e2e && pnpm test:package && node dist/cli.js --version",
    "test:unit": "vitest run test/unit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.34.2",
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
